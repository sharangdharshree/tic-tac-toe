{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es5",
    "lib": ["es5", "es6"],
    "strict": true,
    "rootDir": "./src",
    "outFile": "./build/index.js",
    "typeRoots": ["./node_modules"],
    "types": ["nakama-runtime"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
